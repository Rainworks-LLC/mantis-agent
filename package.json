{
    "name": "@rainworks-llc/mantis-agent",
    "version": "0.1.0",
    "description": "Autonomous, self-constructing agents backed by Ollama",
    "type": "module",
    "bin": {
        "mantis": "dist/index.js"
    },
    "files": [
        "dist",
        "ui"
    ],
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Rainworks-LLC/mantis-agent.git"
    },
    "homepage": "https://github.com/Rainworks-LLC/mantis-agent#readme",
    "bugs": {
        "url": "https://github.com/Rainworks-LLC/mantis-agent/issues"
    },
    "author": "Rainworks LLC",
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "agent",
        "ollama",
        "cli",
        "autonomous"
    ],
    "license": "MIT",
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "@clack/prompts": "^0.9.1",
        "@fastify/static": "^8.1.0",
        "@fastify/websocket": "^11.0.2",
        "@sinclair/typebox": "^0.34.33",
        "chalk": "^5.4.1",
        "commander": "^13.1.0",
        "fastify": "^5.2.1"
    },
    "devDependencies": {
        "@types/node": "^22.15.3",
        "tsup": "^8.4.0",
        "typescript": "^5.8.3",
        "vitest": "^3.1.2"
    }
}